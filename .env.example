# Copy to .env and adjust. All values are optional; sensible dev defaults apply.

# Public base URL used to build login + share links in emails.
# In production this is the hosted domain, e.g. https://meerato.com
BASE_URL=http://localhost:8000

# Secret used to sign tokens. CHANGE THIS in production.
SECRET_KEY=dev-insecure-secret-change-me

# Database (PostgreSQL). docker-compose sets this automatically for the bundled db.
# For a local run, point it at your Postgres instance:
DATABASE_URL=postgresql+psycopg2://meerato:meerato@localhost:5432/meerato

# Credentials for the bundled Postgres container (docker-compose).
POSTGRES_USER=meerato
POSTGRES_PASSWORD=meerato
POSTGRES_DB=meerato

# --- Email ---
# Leave SMTP_HOST empty to print emails (login links, watcher invites) to the
# console — handy for local development without an email provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=todo@localhost
